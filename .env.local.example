# Copy this file to .env.local and fill in with values from your Supabase project:
#   https://supabase.com/dashboard → Project → Settings → API
#
# NEXT_PUBLIC_* vars are exposed to the browser — this is safe because
# Supabase uses Row Level Security (RLS) to enforce access control
# server-side; the anon key alone cannot read/write any table unless
# an RLS policy permits it.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY-HERE
